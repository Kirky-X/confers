{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CacheConfig": {
      "properties": {
        "enabled": {
          "description": "是否启用缓存",
          "type": "boolean"
        },
        "max_entries": {
          "description": "缓存最大条目数",
          "minimum": 0,
          "type": "integer"
        },
        "ttl_seconds": {
          "description": "缓存 TTL（秒）",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "DatabaseConfig": {
      "properties": {
        "database": {
          "description": "数据库名称",
          "type": "string"
        },
        "host": {
          "description": "数据库主机",
          "type": "string"
        },
        "max_connections": {
          "description": "最大连接数",
          "minimum": 1,
          "type": "integer"
        },
        "port": {
          "description": "数据库端口",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "host",
        "port",
        "database"
      ],
      "type": "object"
    },
    "ServerConfig": {
      "properties": {
        "host": {
          "default": "0.0.0.0",
          "description": "主机地址",
          "type": "string"
        },
        "port": {
          "description": "服务器端口",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "timeout_seconds": {
          "description": "连接超时时间（秒）",
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "host",
        "port",
        "timeout_seconds"
      ],
      "type": "object"
    }
  },
  "description": "完整应用配置，包含服务器、数据库和缓存配置",
  "properties": {
    "cache": {
      "$ref": "#/definitions/CacheConfig"
    },
    "database": {
      "$ref": "#/definitions/DatabaseConfig"
    },
    "name": {
      "description": "应用名称",
      "type": "string"
    },
    "server": {
      "$ref": "#/definitions/ServerConfig"
    },
    "version": {
      "description": "应用版本",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    }
  },
  "required": [
    "name",
    "version",
    "server"
  ],
  "title": "FullAppConfig",
  "type": "object"
}